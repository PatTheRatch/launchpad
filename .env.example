# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# .env loading requires python-dotenv (installed via the `tfl` extra). All
# variables can also be set directly in the environment, which is how the
# systemd unit passes LAUNCHPAD_RUN_FOREVER.

# --------------------------------------------------------------------------
# Secrets
# --------------------------------------------------------------------------

# TfL API app key (optional). Without it, requests still work at a lower rate
# limit. Get one at https://api-portal.tfl.gov.uk/.
TFL_APP_KEY=

# --------------------------------------------------------------------------
# Runtime behaviour
# --------------------------------------------------------------------------

# Set to any non-empty value to loop on the refresh interval instead of
# rendering once and exiting. Production (systemd) runs with this set.
#LAUNCHPAD_RUN_FOREVER=1

# Seconds between refreshes in run-forever mode. Default: 300.
#LAUNCHPAD_REFRESH_SECONDS=300

# Pin the dashboard to one time-of-day mode instead of resolving it from the
# clock. Useful in development. One of: morning, daytime, evening, overnight.
#LAUNCHPAD_FORCE_MODE=morning

# --------------------------------------------------------------------------
# Display
# --------------------------------------------------------------------------

# "mock" writes dashboard.png; "eink" will drive the real panel (not yet
# implemented). Default: mock.
#LAUNCHPAD_DISPLAY_DRIVER=mock

# portrait or landscape (landscape renderer not yet implemented).
# Default: portrait.
#LAUNCHPAD_DISPLAY_ORIENTATION=portrait

# Panel dimensions in pixels. Defaults match the Waveshare 7.5" in portrait.
#LAUNCHPAD_DISPLAY_WIDTH=480
#LAUNCHPAD_DISPLAY_HEIGHT=800

# --------------------------------------------------------------------------
# Experimental feature flags (all default off; truthy: 1/true/yes/on)
# --------------------------------------------------------------------------

#LAUNCHPAD_FEATURE_WORLD_CUP=0
#LAUNCHPAD_FEATURE_NBA=0
#LAUNCHPAD_FEATURE_FANTASY_BASKETBALL=0
#LAUNCHPAD_FEATURE_BABY_TRACKING=0
